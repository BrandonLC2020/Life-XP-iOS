#!/bin/bash

# --- Secret Shield ---
echo "Running Secret Shield..."
# Get staged files
STAGED_FILES=$(git diff --cached --name-only)

if [ ! -z "$STAGED_FILES" ]; then
  # Check for common secrets (excluding .skill and binaries)
  SECRETS_FOUND=$(echo "$STAGED_FILES" | xargs grep -E "API_KEY|SECRET|TOKEN|PASSWORD" 2>/dev/null | grep -v ".skill" | grep -v ".png" | grep -v ".xcassets" | grep -v ".jpg")
  if [ ! -z "$SECRETS_FOUND" ]; then
    echo "Error: Possible secrets found in staged files:"
    echo "$SECRETS_FOUND"
    exit 1
  fi
fi

# --- SwiftLint Check ---
if which swiftlint >/dev/null; then
  echo "Running SwiftLint..."
  # Only lint staged Swift files
  SWIFT_FILES=$(echo "$STAGED_FILES" | grep ".swift")
  if [ ! -z "$SWIFT_FILES" ]; then
    swiftlint lint --strict --quiet
    if [ $? -ne 0 ]; then
      echo "SwiftLint failed. Please fix violations before committing."
      exit 1
    fi
  fi
else
  echo "SwiftLint not found, skipping lint check."
fi

exit 0
